# ScraperAPI - get free key at https://www.scraperapi.com
SCRAPER_API_KEY=your_scraperapi_key_here

# Groq API - get free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Product URLs (these are real, public product URLs)
# Product A: "Master Buds 1" → using boAt Airdopes 131 as proxy
MASTER_BUDS_1_AMAZON_URL=https://www.amazon.in/product-reviews/B0CLL2GYKP/ref=cm_cr_arp_d_paging_btm_next_1?ie=UTF8&reviewerType=all_reviews&pageNumber=1
MASTER_BUDS_1_FLIPKART_URL=https://www.flipkart.com/boat-airdopes-131-60h-battery-asap-charge-stream-ad-free-music-via-app-support-bluetooth-headset/product-reviews/itm88e2a3892000a

# Product B: "Master Buds Max" → using boAt Airdopes 441 Pro as proxy
MASTER_BUDS_MAX_AMAZON_URL=https://www.amazon.in/product-reviews/B08CVTT65T/ref=cm_cr_arp_d_paging_btm_next_1?ie=UTF8&reviewerType=all_reviews&pageNumber=1
MASTER_BUDS_MAX_FLIPKART_URL=https://www.flipkart.com/boat-airdopes-441-pro-42h-playback-anc-bluetooth-headset/product-reviews/itm3e53e10fac68c

# Database path
DB_PATH=./db.sqlite

# Slack Integration (Optional)
# For Direct Messages: Create a Slack App, add 'chat:write' scope, install, and get the Bot User OAuth Token
SLACK_BOT_TOKEN=
# The ID of the User to DM (e.g. U12345678) or the Channel ID
SLACK_USER_ID=

# (Legacy) Create an Incoming Webhook in your Slack workspace and paste the URL here
SLACK_WEBHOOK_URL=
